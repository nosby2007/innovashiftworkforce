{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "innovacare-shift-frontend": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/innovacare-shift-frontend/browser",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": [],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/assets",
              "src/manifest.webmanifest",
              "src/firebase-messaging-sw.js",
              "src/robots.txt",
              "src/sitemap.xml"
            ],
            "styles": ["src/material-theme.scss", "src/styles.scss"],
            "scripts": [],
            "serviceWorker": true,
            "ngswConfigPath": "ngsw-config.json",
            "optimization": {
              "scripts": true,
              "styles": {
                "minify": true,
                "inlineCritical": false
              },
              "fonts": {
                "inline": false
              }
            }
          },
          "configurations": {
            "production": {},
            "development": {}
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "innovacare-shift-frontend:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "innovacare-shift-frontend:build:production"
            }
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "runner": "vitest",
            "buildTarget": "innovacare-shift-frontend:build"
          }
        },
        "server": {
          "builder": "@angular-devkit/build-angular:server",
          "options": {
            "outputPath": "dist/innovacare-shift-frontend/server",
            "main": "src/server.ts",
            "tsConfig": "tsconfig.server.json",
            "optimization": true
          },
          "configurations": {
            "production": {},
            "development": {}
          },
          "defaultConfiguration": "production"
        },
        "serve-ssr": {
          "builder": "@angular-devkit/build-angular:ssr-dev-server",
          "configurations": {
            "development": {
              "browserTarget": "innovacare-shift-frontend:build:development",
              "serverTarget": "innovacare-shift-frontend:server:development"
            },
            "production": {
              "browserTarget": "innovacare-shift-frontend:build:production",
              "serverTarget": "innovacare-shift-frontend:server:production"
            }
          },
          "defaultConfiguration": "development"
        },
        "prerender": {
          "builder": "@angular-devkit/build-angular:prerender",
          "options": {
            "discoverRoutes": false,
            "routes": ["/", "/features", "/pricing", "/contact"]
          },
          "configurations": {
            "production": {
              "browserTarget": "innovacare-shift-frontend:build:production",
              "serverTarget": "innovacare-shift-frontend:server:production"
            },
            "development": {
              "browserTarget": "innovacare-shift-frontend:build:development",
              "serverTarget": "innovacare-shift-frontend:server:development"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  },
  "cli": {
    "analytics": "7b672f2a-3243-4a3f-8c4a-09adb01a2135"
  }
}
