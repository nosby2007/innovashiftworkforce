rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function tokenOrgId() {
      return signedIn() ? request.auth.token.orgId : null;
    }

    function accessRole() {
      return signedIn() ? request.auth.token.accessRole : null;
    }

    function platformRole() {
      return signedIn() ? request.auth.token.platformRole : null;
    }

    function isSuperAdmin() {
      return signedIn() && platformRole() in ['superAdmin', 'super_admin', 'super-admin'];
    }

    // Custom claims (orgId in the ID token) are only refreshed on next login or
    // natural token expiry — a user invited/reassigned mid-session can have a
    // stale token that still passes the app's own Firestore-backed fallback
    // context but fails a token-only check here. Fall back to the authoritative
    // Firestore org-membership doc so uploads don't silently break for anyone
    // whose token just hasn't refreshed yet.
    function isFirestoreOrgMember(orgId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/orgs/$(orgId)/users/$(request.auth.uid));
    }

    function isOrgMember(orgId) {
      return signedIn() && (tokenOrgId() == orgId || isFirestoreOrgMember(orgId));
    }

    function isOrgAdminLike(orgId) {
      return isSuperAdmin()
        || (isOrgMember(orgId) && accessRole() in ['admin', 'manager', 'scheduler', 'hr']);
    }

    function isSafeUpload(maxBytes) {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches(
          '(image/.*|application/pdf|text/plain|text/csv|application/vnd\\.ms-excel)'
        );
    }

    match /orgs/{orgId}/users/{uid}/{fileName=**} {
      allow read: if isSuperAdmin()
        || isOrgAdminLike(orgId)
        || (isOrgMember(orgId) && request.auth.uid == uid);

      allow create, update: if (
          isSuperAdmin()
          || isOrgAdminLike(orgId)
          || (isOrgMember(orgId) && request.auth.uid == uid)
        )
        && isSafeUpload(10 * 1024 * 1024);

      allow delete: if isSuperAdmin()
        || isOrgAdminLike(orgId)
        || (isOrgMember(orgId) && request.auth.uid == uid);
    }

    match /orgs/{orgId}/shifts/{shiftId}/{fileName=**} {
      allow read: if isSuperAdmin() || isOrgMember(orgId);
      allow create, update: if isOrgAdminLike(orgId) && isSafeUpload(10 * 1024 * 1024);
      allow delete: if isOrgAdminLike(orgId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
