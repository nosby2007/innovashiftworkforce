rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    // .get(key, default) tolerates tokens that don't carry a custom claim yet
    // (e.g. a session still on an old ID token from before the claim was
    // set) — a plain `.orgId` accessor throws on a missing claim, which
    // Storage rules treat as a deny, surfacing as a generic
    // storage/unknown error instead of a clean permission check. Mirrors
    // the same fix already applied in firestore.rules.
    function tokenOrgId() {
      return signedIn() ? request.auth.token.get('orgId', null) : null;
    }

    function accessRole() {
      return signedIn() ? request.auth.token.get('accessRole', null) : null;
    }

    function platformRole() {
      return signedIn() ? request.auth.token.get('platformRole', null) : null;
    }

    function isSuperAdmin() {
      return signedIn() && platformRole() in ['superAdmin', 'super_admin', 'super-admin'];
    }

    // Custom claims (orgId in the ID token) are only refreshed on next login or
    // natural token expiry — a user invited/reassigned mid-session can have a
    // stale token that still passes the app's own Firestore-backed fallback
    // context but fails a token-only check here. Fall back to the authoritative
    // Firestore org-membership doc so uploads don't silently break for anyone
    // whose token just hasn't refreshed yet.
    function isFirestoreOrgMember(orgId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/orgs/$(orgId)/users/$(request.auth.uid));
    }

    function isOrgMember(orgId) {
      return signedIn() && (tokenOrgId() == orgId || isFirestoreOrgMember(orgId));
    }

    function isOrgAdminLike(orgId) {
      return isSuperAdmin()
        || (isOrgMember(orgId) && accessRole() in ['admin', 'manager', 'scheduler', 'hr']);
    }

    // Discretionary/sensitive files (employee identity docs, W-4/W-2, etc.)
    // — admin and hr only, narrower than isOrgAdminLike(). Mirrors
    // isAdminOrHR() in firestore.rules, which already gates the matching
    // employeeDocuments collection this way.
    function isOrgAdminOrHR(orgId) {
      return isSuperAdmin()
        || (isOrgMember(orgId) && accessRole() in ['admin', 'hr']);
    }

    function isSafeUpload(maxBytes) {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches(
          '(image/.*|application/pdf|text/plain|text/csv|application/vnd\\.ms-excel)'
        );
    }

    // Sensitive employee documents (identity, W-4/W-2, certifications) —
    // narrower than the general per-user path below: only the employee
    // themselves and admin/hr can read or write these, not manager/scheduler.
    match /orgs/{orgId}/users/{uid}/documents/{fileName=**} {
      allow read: if isOrgAdminOrHR(orgId)
        || (isOrgMember(orgId) && request.auth.uid == uid);

      allow create, update: if (
          isOrgAdminOrHR(orgId)
          || (isOrgMember(orgId) && request.auth.uid == uid)
        )
        && isSafeUpload(10 * 1024 * 1024);

      allow delete: if isOrgAdminOrHR(orgId)
        || (isOrgMember(orgId) && request.auth.uid == uid);
    }

    match /orgs/{orgId}/users/{uid}/{fileName=**} {
      allow read: if isSuperAdmin()
        || isOrgAdminLike(orgId)
        || (isOrgMember(orgId) && request.auth.uid == uid);

      allow create, update: if (
          isSuperAdmin()
          || isOrgAdminLike(orgId)
          || (isOrgMember(orgId) && request.auth.uid == uid)
        )
        && isSafeUpload(10 * 1024 * 1024);

      allow delete: if isSuperAdmin()
        || isOrgAdminLike(orgId)
        || (isOrgMember(orgId) && request.auth.uid == uid);
    }

    match /orgs/{orgId}/shifts/{shiftId}/{fileName=**} {
      allow read: if isSuperAdmin() || isOrgMember(orgId);
      allow create, update: if isOrgAdminLike(orgId) && isSafeUpload(10 * 1024 * 1024);
      allow delete: if isOrgAdminLike(orgId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
